# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite client.
# Set this in local development or in your deployment platform's environment config.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_MODEL: Optional Gemini model override.
# Defaults to gemini-2.5-flash when omitted.
VITE_GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
